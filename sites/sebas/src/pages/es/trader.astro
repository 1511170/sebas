---
import LayoutTrader from '../../layouts/LayoutTrader.astro';
---

<LayoutTrader
  title="Escalado para Traders Profesionales"
  description="Infraestructura para profesionales independientes. Escala de $10K/mes a $100K+ sin operar más. Acceso institucional con Sebas.co."
  locale="es"
  keywords={["trader profesional crypto", "escalado trading", "copy trading español", "servicio señales crypto", "acceso institucional trader", "BingX trader profesional", "scalper cripto", "swing trader", "quant trading", "gestión activos crypto"]}
>
  <main class="pt-20 flex flex-col min-h-screen">
    <!-- Hero -->
    <section class="relative px-6 py-16 lg:px-20 lg:py-24 border-b border-[#303928] bg-[radial-gradient(ellipse_at_top_right,_#1f2818,_#1d2419_40%,_#141811)]">
      <div class="max-w-[1200px] mx-auto grid lg:grid-cols-2 gap-12 items-center">
        <div class="flex flex-col gap-6">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[#8cf425]/20 bg-[#8cf425]/5 w-fit">
            <span class="w-2 h-2 rounded-full bg-[#8cf425] animate-pulse" />
            <span class="text-[#8cf425] text-xs font-bold uppercase tracking-wider">Acceso Institucional Exclusivo</span>
          </div>
          <h1 class="text-4xl lg:text-6xl font-black leading-[1.1] tracking-tight">
            ¿Generando <span class="text-[#8cf425]">$10K/mes</span> trading? <br />
            Genera <span class="text-white underline decoration-[#8cf425] decoration-4 underline-offset-4">$100K</span> sin abrir otra posición.
          </h1>
          <p class="text-[#abba9c] text-lg lg:text-xl font-normal leading-relaxed max-w-xl">
            Infraestructura para profesionales independientes. Deja de cambiar tiempo por dinero. Convierte tu edge en una clase de activo.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mt-4">
            <a
              href="https://cal.com/sebasco/professional-trader"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 rounded-lg h-12 px-8 bg-[#8cf425] hover:bg-[#6ab818] transition-all text-[#141811] text-base font-bold"
            >
              <span>Aplicar al Programa de Escalado</span>
              <span class="material-symbols-outlined text-lg">arrow_outward</span>
            </a>
            <a
              href="#kpi"
              class="flex items-center justify-center gap-2 rounded-lg h-12 px-8 border border-[#303928] hover:border-[#8cf425]/50 bg-[#1d2419] hover:bg-[#252e20] transition-all text-white text-base font-medium"
            >
              <span>Ver Datos de Rendimiento</span>
            </a>
          </div>
        </div>

        <!-- Chart visualization -->
        <div class="relative w-full h-[400px] rounded-xl border border-[#303928] bg-[#1d2419]/50 p-6 flex flex-col justify-between overflow-hidden group">
          <div class="absolute inset-0 opacity-20 bg-[length:40px_40px]" style="background-image: linear-gradient(to right, #303928 1px, transparent 1px), linear-gradient(to bottom, #303928 1px, transparent 1px)" />
          <div class="flex justify-between items-start z-10">
            <div>
              <p class="text-[#abba9c] text-xs uppercase tracking-wider font-semibold">Proyección de Escalado</p>
              <h3 class="text-3xl font-bold text-white mt-1">$124,502<span class="text-[#8cf425] text-lg ml-1">.00</span></h3>
              <div class="flex items-center gap-1 mt-1 text-[#8cf425] text-sm font-medium bg-[#8cf425]/10 px-2 py-0.5 rounded w-fit">
                <span class="material-symbols-outlined text-sm">trending_up</span>
                <span>+842% vs Manual</span>
              </div>
            </div>
            <div class="flex gap-2">
              <div class="w-3 h-3 rounded-full bg-red-500/20 border border-red-500" />
              <div class="w-3 h-3 rounded-full bg-yellow-500/20 border border-yellow-500" />
              <div class="w-3 h-3 rounded-full bg-[#8cf425]/20 border border-[#8cf425]" />
            </div>
          </div>
          <div class="relative h-48 w-full z-10 mt-auto">
            <div class="absolute inset-0 bg-gradient-to-t from-[#8cf425]/20 to-transparent rounded-b" style="clip-path: polygon(0 100%, 0 20%, 25% 15%, 50% 25%, 75% 10%, 100% 5%, 100% 100%)" />
            <svg class="w-full h-full overflow-visible" viewBox="0 0 100 50" preserveAspectRatio="none">
              <path d="M0,45 L20,44 L40,45 L50,44" fill="none" stroke="#555" stroke-dasharray="2 2" stroke-width="0.5" />
              <path d="M0,45 C20,44 40,40 60,25 C80,10 90,5 100,0" fill="none" stroke="#8cf425" stroke-width="1.5" vector-effect="non-scaling-stroke" />
              <path d="M0,45 C20,44 40,40 60,25 C80,10 90,5 100,0" fill="none" stroke="#8cf425" stroke-opacity="0.2" stroke-width="4" vector-effect="non-scaling-stroke" />
              <circle cx="60" cy="25" fill="#141811" r="2" stroke="#8cf425" stroke-width="1" />
            </svg>
            <div class="absolute top-[30%] left-[58%] bg-[#252e20] border border-[#303928] p-2 rounded shadow-xl">
              <p class="text-[10px] text-[#abba9c] uppercase">Despliegue de Capital</p>
              <p class="text-sm font-bold text-white">$2.4M AUM</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- KPI Strip -->
    <section id="kpi" class="border-b border-[#303928] bg-[#1d2419]">
      <div class="max-w-[1200px] mx-auto px-6 py-8 flex flex-wrap gap-8 justify-around">
        <div class="flex flex-col gap-1 items-center text-center">
          <p class="text-[#abba9c] text-sm font-medium uppercase tracking-wide">Ingreso Promedio de Mesa</p>
          <p class="text-2xl font-bold text-white tracking-tight">$125k<span class="text-sm text-[#abba9c] font-normal">/mes</span></p>
        </div>
        <div class="w-px h-12 bg-[#303928] hidden sm:block" />
        <div class="flex flex-col gap-1 items-center text-center">
          <p class="text-[#abba9c] text-sm font-medium uppercase tracking-wide">Factor de Escalado</p>
          <p class="text-2xl font-bold text-white tracking-tight">10x <span class="text-[#8cf425] text-sm font-bold">Apalancamiento</span></p>
        </div>
        <div class="w-px h-12 bg-[#303928] hidden sm:block" />
        <div class="flex flex-col gap-1 items-center text-center">
          <p class="text-[#abba9c] text-sm font-medium uppercase tracking-wide">Retención de Traders</p>
          <p class="text-2xl font-bold text-white tracking-tight">94% <span class="text-sm text-[#abba9c] font-normal">anual</span></p>
        </div>
      </div>
    </section>

    <!-- Pain: The Hamster Wheel -->
    <section class="px-6 py-20 lg:px-20 bg-[#141811]">
      <div class="max-w-[1200px] mx-auto">
        <div class="mb-12">
          <h2 class="text-3xl lg:text-4xl font-bold mb-4">
            La Rueda del Hámster: <br /><span class="text-[#abba9c]">Por Qué el Trading Manual No Escala</span>
          </h2>
          <p class="text-[#abba9c] max-w-2xl text-lg">
            Más capital significa más estrés, slippage y presión psicológica. Nuestro ecosistema desacopla tus ingresos del tiempo que pasas mirando gráficos.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="group p-6 rounded-lg border border-[#303928] bg-[#1d2419] hover:border-[#8cf425]/30 transition-all duration-300">
            <div class="w-12 h-12 rounded bg-[#252e20] flex items-center justify-center mb-4 group-hover:bg-[#8cf425]/10 transition-colors">
              <span class="material-symbols-outlined text-white group-hover:text-[#8cf425]">timer</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Insolvencia de Tiempo</h3>
            <p class="text-[#abba9c] text-sm leading-relaxed">
              Solo puedes mirar tantos gráficos. Tus ingresos están limitados por tu capacidad física.
            </p>
            <div class="mt-4 pt-4 border-t border-[#303928] flex justify-between items-center text-xs text-[#abba9c]">
              <span>Estado</span>
              <span class="text-red-400 font-bold">No Escalable</span>
            </div>
          </div>
          <div class="group p-6 rounded-lg border border-[#303928] bg-[#1d2419] hover:border-[#8cf425]/30 transition-all duration-300">
            <div class="w-12 h-12 rounded bg-[#252e20] flex items-center justify-center mb-4 group-hover:bg-[#8cf425]/10 transition-colors">
              <span class="material-symbols-outlined text-white group-hover:text-[#8cf425]">psychology</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Techo Psicológico</h3>
            <p class="text-[#abba9c] text-sm leading-relaxed">
              Gestionar $10M se siente biológicamente diferente a $100K. El cortisol escala linealmente con el tamaño de la posición.
            </p>
            <div class="mt-4 pt-4 border-t border-[#303928] flex justify-between items-center text-xs text-[#abba9c]">
              <span>Riesgo</span>
              <span class="text-red-400 font-bold">Alto Riesgo de Agotamiento</span>
            </div>
          </div>
          <div class="group p-6 rounded-lg border border-[#303928] bg-[#1d2419] hover:border-[#8cf425]/30 transition-all duration-300">
            <div class="w-12 h-12 rounded bg-[#252e20] flex items-center justify-center mb-4 group-hover:bg-[#8cf425]/10 transition-colors">
              <span class="material-symbols-outlined text-white group-hover:text-[#8cf425]">warning</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Arrastre de Ejecución</h3>
            <p class="text-[#abba9c] text-sm leading-relaxed">
              El slippage y los problemas de liquidez consumen el alpha al escalar. La ejecución manual falla a tamaño institucional.
            </p>
            <div class="mt-4 pt-4 border-t border-[#303928] flex justify-between items-center text-xs text-[#abba9c]">
              <span>Eficiencia</span>
              <span class="text-red-400 font-bold">En Declive</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trader Personas -->
    <section id="personas" class="px-6 py-20 lg:px-20 bg-[#1d2419] border-y border-[#303928]">
      <div class="max-w-[1200px] mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
          <div>
            <span class="text-[#8cf425] font-bold text-sm tracking-widest uppercase mb-2 block">A Quiénes Financiamos</span>
            <h2 class="text-3xl font-bold text-white">Selecciona Tu Arquetipo</h2>
          </div>
          <div class="flex gap-2 p-1 bg-[#141811] rounded-lg border border-[#303928]">
            <button type="button" class="px-4 py-2 bg-[#252e20] rounded text-sm font-medium text-white shadow-sm">Activo</button>
            <button type="button" class="px-4 py-2 hover:bg-[#252e20] rounded text-sm font-medium text-[#abba9c] transition-colors">Financiado</button>
          </div>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <!-- Scalper -->
          <div class="relative bg-[#141811] border-2 border-[#303928] rounded-xl p-6 hover:border-[#8cf425]/50 transition-all group overflow-hidden">
            <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
              <span class="material-symbols-outlined text-6xl">bolt</span>
            </div>
            <div class="flex items-center gap-3 mb-6">
              <span class="px-2 py-1 bg-blue-500/10 text-blue-400 text-xs font-bold uppercase rounded border border-blue-500/20">Alta Frecuencia</span>
              <span class="h-px flex-1 bg-[#303928]" />
            </div>
            <h3 class="text-2xl font-bold text-white mb-1">El Scalper</h3>
            <p class="text-[#abba9c] text-sm mb-6">La velocidad de ejecución es tu alpha. Necesitas infraestructura, no solo capital.</p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-start gap-3 text-sm text-[#abba9c]">
                <span class="material-symbols-outlined text-[#8cf425] text-lg">check_circle</span>
                <span>Routing institucional de latencia cero</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-[#abba9c]">
                <span class="material-symbols-outlined text-[#8cf425] text-lg">check_circle</span>
                <span>Estructuras de rebate a nivel de exchange</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-[#abba9c]">
                <span class="material-symbols-outlined text-[#8cf425] text-lg">check_circle</span>
                <span>Acceso a datos a nivel de tick</span>
              </li>
            </ul>
            <a href="#apply" class="block w-full py-3 border border-[#303928] rounded bg-[#1d2419] text-white text-sm font-bold hover:bg-white hover:text-[#141811] transition-colors text-center">
              Desplegar Infra de Scalper
            </a>
          </div>
          <!-- Swing -->
          <div class="relative bg-[#141811] border-2 border-[#303928] rounded-xl p-6 hover:border-[#8cf425]/50 transition-all group overflow-hidden">
            <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
              <span class="material-symbols-outlined text-6xl">show_chart</span>
            </div>
            <div class="flex items-center gap-3 mb-6">
              <span class="px-2 py-1 bg-purple-500/10 text-purple-400 text-xs font-bold uppercase rounded border border-purple-500/20">Macro / Swing</span>
              <span class="h-px flex-1 bg-[#303928]" />
            </div>
            <h3 class="text-2xl font-bold text-white mb-1">El Swing Trader</h3>
            <p class="text-[#abba9c] text-sm mb-6">Capturas los grandes movimientos. Necesitas liquidez profunda para entrar y salir sin slippage.</p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-start gap-3 text-sm text-[#abba9c]">
                <span class="material-symbols-outlined text-[#8cf425] text-lg">check_circle</span>
                <span>Acceso a liquidez de dark pool</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-[#abba9c]">
                <span class="material-symbols-outlined text-[#8cf425] text-lg">check_circle</span>
                <span>Holdings multi-día sin comisiones de swap</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-[#abba9c]">
                <span class="material-symbols-outlined text-[#8cf425] text-lg">check_circle</span>
                <span>Soporte de equipo analista</span>
              </li>
            </ul>
            <a href="#apply" class="block w-full py-3 border border-[#303928] rounded bg-[#1d2419] text-white text-sm font-bold hover:bg-white hover:text-[#141811] transition-colors text-center">
              Acceder a Liquidez Profunda
            </a>
          </div>
          <!-- Quant -->
          <div class="relative bg-[#141811] border-2 border-[#303928] rounded-xl p-6 hover:border-[#8cf425]/50 transition-all group overflow-hidden">
            <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
              <span class="material-symbols-outlined text-6xl">code</span>
            </div>
            <div class="flex items-center gap-3 mb-6">
              <span class="px-2 py-1 bg-[#8cf425]/10 text-[#8cf425] text-xs font-bold uppercase rounded border border-[#8cf425]/20">Cuantitativo</span>
              <span class="h-px flex-1 bg-[#303928]" />
            </div>
            <h3 class="text-2xl font-bold text-white mb-1">El Quant</h3>
            <p class="text-[#abba9c] text-sm mb-6">Tu ventaja es matemática. Necesitas co-ubicación y límites robustos de API.</p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-start gap-3 text-sm text-[#abba9c]">
                <span class="material-symbols-outlined text-[#8cf425] text-lg">check_circle</span>
                <span>Acceso directo API (FIX/REST/WS)</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-[#abba9c]">
                <span class="material-symbols-outlined text-[#8cf425] text-lg">check_circle</span>
                <span>Co-ubicación de servidor dedicado</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-[#abba9c]">
                <span class="material-symbols-outlined text-[#8cf425] text-lg">check_circle</span>
                <span>Sandbox de entorno de backtesting</span>
              </li>
            </ul>
            <a href="#apply" class="block w-full py-3 border border-[#303928] rounded bg-[#1d2419] text-white text-sm font-bold hover:bg-white hover:text-[#141811] transition-colors text-center">
              Conectar API
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Ecosystem Multiplication -->
    <section id="ecosystem" class="px-6 py-20 lg:px-20 bg-[#141811]">
      <div class="max-w-[1200px] mx-auto">
        <div class="grid lg:grid-cols-2 gap-16">
          <div class="flex flex-col justify-center">
            <h2 class="text-3xl lg:text-4xl font-bold mb-6">
              Multiplicación del <span class="text-[#8cf425]">Ecosistema</span>
            </h2>
            <p class="text-[#abba9c] text-lg mb-8 leading-relaxed">
              No solo te financiamos. Productizamos tus datos de trading. Mientras te concentras en PnL, nuestro backend distribuye tu señal a inversores retail, instituciones e individuos de alto patrimonio.
            </p>
            <div class="space-y-6">
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded bg-[#1d2419] border border-[#303928] flex items-center justify-center text-[#8cf425] font-bold text-xl">1</div>
                <div>
                  <h4 class="text-white font-bold text-lg">Tú Operas</h4>
                  <p class="text-[#abba9c] text-sm">Continúa haciendo exactamente lo que haces ahora. Sin trabajo extra.</p>
                </div>
              </div>
              <div class="w-px h-8 bg-[#303928] ml-6" />
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded bg-[#1d2419] border border-[#303928] flex items-center justify-center text-[#8cf425] font-bold text-xl">2</div>
                <div>
                  <h4 class="text-white font-bold text-lg">Nosotros Replicamos</h4>
                  <p class="text-[#abba9c] text-sm">Nuestros motores copian tus operaciones en nuestro pool de inversores.</p>
                </div>
              </div>
              <div class="w-px h-8 bg-[#303928] ml-6" />
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded bg-[#8cf425] text-[#141811] font-bold text-xl flex items-center justify-center">3</div>
                <div>
                  <h4 class="text-white font-bold text-lg">Tú Ganas Múltiplos</h4>
                  <p class="text-[#abba9c] text-sm">Comisiones de performance de cada seguidor, agregadas mensualmente.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4" id="revenue">
            <div class="bg-[#1d2419] border-2 border-[#303928] p-5 rounded-lg">
              <div class="flex justify-between items-start mb-4">
                <span class="text-white font-bold">Copy Trading</span>
                <span class="text-xs font-mono text-[#8cf425] bg-[#8cf425]/10 px-2 py-1 rounded">20% Comisión</span>
              </div>
              <div class="h-16 w-full relative mb-2">
                <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 64">
                  <defs>
                    <linearGradient id="grad-copy-es" x1="0%" x2="0%" y1="0%" y2="100%">
                      <stop offset="0%" style="stop-color:#8cf425;stop-opacity:1" />
                      <stop offset="100%" style="stop-color:#8cf425;stop-opacity:0" />
                    </linearGradient>
                  </defs>
                  <path d="M0,60 C20,55 40,40 60,30 C80,25 100,5" fill="none" stroke="#8cf425" stroke-width="2" vector-effect="non-scaling-stroke" />
                  <path d="M0,60 C20,55 40,40 60,30 C80,25 100,5 V64 H0 Z" fill="url(#grad-copy-es)" opacity="0.2" />
                </svg>
              </div>
              <p class="text-xs text-[#abba9c]">Ingresos pasivos de 500+ copiadores siguiendo tu estrategia verificada.</p>
            </div>
            <div class="bg-[#1d2419] border-2 border-[#303928] p-5 rounded-lg">
              <div class="flex justify-between items-start mb-4">
                <span class="text-white font-bold">Servicio de Señales</span>
                <span class="text-xs font-mono text-[#8cf425] bg-[#8cf425]/10 px-2 py-1 rounded">$99/mes Sub</span>
              </div>
              <div class="h-16 w-full relative mb-2">
                <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 64">
                  <defs>
                    <linearGradient id="grad-signal-es" x1="0%" x2="0%" y1="0%" y2="100%">
                      <stop offset="0%" style="stop-color:#8cf425;stop-opacity:1" />
                      <stop offset="100%" style="stop-color:#8cf425;stop-opacity:0" />
                    </linearGradient>
                  </defs>
                  <path d="M0,50 L20,50 L30,30 L50,30 L60,10 L100,5" fill="none" stroke="#8cf425" stroke-width="2" vector-effect="non-scaling-stroke" />
                  <path d="M0,50 L20,50 L30,30 L50,30 L60,10 L100,5 V64 H0 Z" fill="url(#grad-signal-es)" opacity="0.2" />
                </svg>
              </div>
              <p class="text-xs text-[#abba9c]">Alertas automáticas enviadas a suscriptores via integración Telegram/Discord.</p>
            </div>
            <div class="bg-[#1d2419] border-2 border-[#303928] p-5 rounded-lg sm:col-span-2">
              <div class="flex justify-between items-start mb-4">
                <span class="text-white font-bold">Gestión de Activos</span>
                <span class="text-xs font-mono text-[#8cf425] bg-[#8cf425]/10 px-2 py-1 rounded">Modelo 2/20</span>
              </div>
              <div class="flex gap-8 items-center">
                <div class="h-16 w-1/2 min-w-[120px]">
                  <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 64">
                    <defs>
                      <linearGradient id="grad-asset-es" x1="0%" x2="0%" y1="0%" y2="100%">
                        <stop offset="0%" style="stop-color:#8cf425;stop-opacity:1" />
                        <stop offset="100%" style="stop-color:#8cf425;stop-opacity:0" />
                      </linearGradient>
                    </defs>
                    <path d="M0,60 Q50,60 100,10" fill="none" stroke="#8cf425" stroke-width="2" vector-effect="non-scaling-stroke" />
                    <path d="M0,60 Q50,60 100,10 V64 H0 Z" fill="url(#grad-asset-es)" opacity="0.2" />
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="text-2xl font-bold text-white mb-1">$500k+</p>
                  <p class="text-xs text-[#abba9c]">Asignaciones para track records probados > 6 meses.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</LayoutTrader>
