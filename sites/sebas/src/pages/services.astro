---
import Layout from '../layouts/Layout.astro';
import ServicesContent from '../components/sections/ServicesContent.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import { t } from '../i18n/index';

const locale = 'en';
const meta = t(locale).meta as any;
---

<Layout
  title={meta.services_title}
  description={meta.services_description}
  locale={locale}
>
  <Fragment slot="head">
    <SchemaOrg
      type="FinancialService"
      siteLanguage={locale}
      data={{
        name: 'Sebas.co Elite Services',
        description: meta.services_description,
        serviceType: 'Crypto institutional infrastructure',
        areaServed: 'Global',
        fees: 'Revenue sharing and performance-based models'
      }}
    />
  </Fragment>
  <main id="main-content">
    <ServicesContent locale={locale} />
  </main>
</Layout>
