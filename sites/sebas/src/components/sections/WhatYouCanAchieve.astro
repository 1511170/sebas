---
import { t } from '../../i18n/index';
import type { SiteLocale } from '../../i18n/index';

interface Props { locale?: SiteLocale; }
const { locale = 'en' } = Astro.props;
const c = t(locale).achieve as any;
const features = c.features;
---

<section class="py-24 bg-white text-black">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Heading -->
    <div class="mb-16">
      <h4 class="text-purple-800 font-bold uppercase tracking-wider text-sm mb-4">
        {c.eyebrow}
      </h4>
      <h2 class="font-display text-5xl md:text-6xl font-black uppercase leading-none mb-2">
        {c.title1}<br/>{c.title2}
      </h2>
      <h2 class="font-display text-5xl md:text-6xl font-black uppercase italic">
        Sebas.co
      </h2>
    </div>

    <!-- Feature grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-16">
      {features.map(feature => (
        <div class="group">
          <div class="w-12 h-12 bg-black text-primary rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <span class="material-icons-outlined">{feature.icon}</span>
          </div>
          <h3 class="text-xl font-bold mb-3">{feature.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>

    <!-- Quote -->
    <div class="mt-20 border-l-4 border-purple-600 pl-6 py-2">
      <p class="text-xl md:text-2xl font-semibold text-purple-800 italic">
        {c.quote}
      </p>
    </div>
  </div>
</section>
