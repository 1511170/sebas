---
import { t } from '../../i18n/index';
import type { SiteLocale } from '../../i18n/index';

interface Props { locale?: SiteLocale; }
const { locale = 'en' } = Astro.props;
const c = t(locale).different as any;

const images = [
  'https://images.unsplash.com/photo-1557804506-669a67965ba0?w=800&q=80',
  'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80',
  'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=800&q=80',
  'https://images.unsplash.com/photo-1560472354-b33ff0c44a43?w=800&q=80',
];

const differentiators = c.items.map((item: any, i: number) => ({
  ...item,
  image: images[i],
  imageAlt: item.title,
  reverse: i % 2 !== 0,
}));
---

<section id="servicios" class="py-24 bg-white text-black">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Heading -->
    <div class="text-center mb-20">
      <p class="text-purple-800 font-bold text-sm uppercase tracking-widest mb-4">
        {c.eyebrow}
      </p>

      <!-- Volume highlight -->
      <div class="inline-block bg-primary px-8 py-4 rounded-lg transform -rotate-1 mb-8 shadow-lg">
        <h3 class="text-xl md:text-3xl font-black uppercase text-center leading-tight text-black">
          {c.volume}<br/>
          <span class="text-4xl md:text-5xl">{c.volume_range}</span><br/>
          {c.volume_period}
        </h3>
      </div>

      <h2 class="font-display text-5xl md:text-6xl font-black uppercase mt-4">
        {c.title} <span class="italic">{c.title_italic}</span><br/>{c.title_suffix}
      </h2>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line (desktop) -->
      <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-px bg-purple-200 hidden md:block"></div>

      {differentiators.map(item => (
        <div class={`flex flex-col ${item.reverse ? 'md:flex-row-reverse' : 'md:flex-row'} items-center mb-16 relative`}>

          <!-- Image -->
          <div class={`w-full md:w-1/2 ${item.reverse ? 'pl-0 md:pl-12 mb-8 md:mb-0' : 'pr-0 md:pr-12 mb-8 md:mb-0'}`}>
            <div class="rounded-2xl overflow-hidden shadow-2xl border border-gray-100">
              <img
                src={item.image}
                alt={item.imageAlt}
                class="w-full h-64 object-cover"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Timeline number (desktop) -->
          <div class="absolute left-1/2 transform -translate-x-1/2 w-10 h-10 bg-primary rounded-full border-4 border-white flex items-center justify-center font-bold text-sm z-10 hidden md:flex text-black">
            {item.number}
          </div>

          <!-- Text -->
          <div class={`w-full md:w-1/2 ${item.reverse ? 'pr-0 md:pr-12 text-left md:text-right' : 'pl-0 md:pl-12'}`}>
            <h3 class="text-2xl font-bold mb-3">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
