---
import bitunixLogo from '../../assets/bitunix-sebas-co-p-2600.png';
import bingxLogo from '../../assets/bingx-logo.svg';

const perfiles = [
  { label: 'KOL / Influencer', href: '/kol' },
  { label: 'Trader', href: '/trader' },
  { label: 'Funds', href: '/fund' },
  { label: 'Platform', href: '/platform' },
  { label: 'FAQs', href: '/faqs' },
];

const redes = [
  { label: 'Linkedin', href: '#' },
  { label: 'Twitter / X', href: '#' },
  { label: 'Instagram', href: '#' },
];

const partners = [
  { name: 'Bitunix', src: bitunixLogo.src, alt: 'Bitunix with Sebas.co' },
  { name: 'BingX', src: bingxLogo.src, alt: 'BingX' },
];
---

<footer
  class="w-full min-w-full text-white border-t border-gray-900/80"
  style="background: linear-gradient(180deg, #0a0a0a 0%, #050505 50%, #000000 100%);"
>
  <!-- CTA principal -->
  <div class="max-w-4xl mx-auto px-4 pt-24 pb-20 text-center">
    <p class="text-primary text-xs font-bold uppercase tracking-widest mb-6 leading-relaxed">
      "While you read this,<br/>
      your competitors are taking positions.<br/>
      Exchanges are closing deals.<br/>
      Opportunities are running out."
    </p>
    <h2 class="font-display text-4xl md:text-6xl font-black uppercase mb-12 leading-tight">
      Will you be part of the<br/>
      <span class="text-gradient bg-gradient-to-r from-white to-gray-400">1% that dominates...</span> or<br/>
      the 99% that<br/>
      <span class="text-gradient bg-gradient-to-r from-gray-400 to-gray-600">watches?</span>
    </h2>
    <a
      href="https://cal.com/sebasco/15min"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block bg-primary text-black px-10 py-5 rounded-full text-base font-bold uppercase tracking-widest hover:bg-white transition-all transform hover:scale-105 shadow-glow"
    >
      Schedule Strategic Call
    </a>

    <!-- Backed by the best -->
    <p class="text-xs uppercase tracking-[0.2em] text-gray-500 mb-8 font-bold mt-16">
      Backed by the best
    </p>
    <div class="flex flex-wrap justify-center items-center gap-12 opacity-90 hover:opacity-100 transition-all duration-500">
      {partners.map(partner => (
        <img
          src={partner.src}
          alt={partner.alt}
          width="200"
          height="56"
          class="h-12 md:h-14 w-auto max-w-[200px] object-contain"
          loading="lazy"
        />
      ))}
    </div>
  </div>

  <!-- Links del footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 border-t border-gray-800 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">

      <!-- Logo -->
      <div class="col-span-1">
        <span class="font-display italic text-3xl text-white font-bold tracking-tighter">Sebas</span>
        <p class="text-xs text-gray-500 mt-2">Connecting Financial Technology</p>
      </div>

      <!-- Contact -->
      <div class="col-span-1">
        <h4 class="font-bold text-sm uppercase mb-4 tracking-wider">Contact</h4>
        <p class="text-xs text-gray-400 mb-2">hello@sebas.co</p>
        <p class="font-bold text-xs uppercase mb-2 tracking-wider mt-4">Where we are</p>
        <p class="text-xs text-gray-400">USA</p>
        <p class="text-xs text-gray-400">Europa</p>
        <p class="text-xs text-gray-400">Africa</p>
        <p class="text-xs text-gray-400">Latam</p>
      </div>

      <!-- Profiles -->
      <div class="col-span-1">
        <h4 class="font-bold text-sm uppercase mb-4 tracking-wider">Profiles</h4>
        <ul class="space-y-2">
          {perfiles.map(item => (
            <li>
              <a href={item.href} class="text-xs text-gray-400 hover:text-primary transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div class="col-span-1">
        <h4 class="font-bold text-sm uppercase mb-4 tracking-wider">Connect</h4>
        <ul class="space-y-2">
          {redes.map(item => (
            <li>
              <a href={item.href} class="text-xs text-gray-400 hover:text-primary transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-16 flex flex-col md:flex-row justify-between items-center text-xs text-gray-600">
      <p>© {new Date().getFullYear()} Sebas CO LLC. All rights reserved.</p>
      <div class="flex space-x-6 mt-4 md:mt-0">
        <a href="#" class="hover:text-white transition-colors">Terms</a>
        <a href="#" class="hover:text-white transition-colors">Privacy</a>
      </div>
    </div>
  </div>
</footer>
