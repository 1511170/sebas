---
import '../styles/global.css';
import siteConfig from '../../config/site.config.ts';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import FloatingTelegram from '../components/shared/FloatingTelegram.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import { getPathWithoutLocale } from '../i18n/index';

interface Props {
  title?: string;
  description?: string;
  locale?: string;
  keywords?: string[];
}

const {
  title = 'Sebas.co Institutional',
  description = 'Institutional-grade infrastructure for the next generation of assets. Frictionless, regulated, built for allocators and funds.',
  locale = 'en',
  keywords = [],
} = Astro.props;

const siteName = siteConfig.site.name;
const titleFull = `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titleFull}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <meta name="robots" content="index, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={titleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />

    <!-- Keywords -->
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

    <!-- AEO: AI Citation Hints -->
    <meta name="citation_title" content={titleFull} />
    <meta name="citation_author" content={siteName} />
    <meta name="citation_language" content={locale} />
    <meta name="citation_publication_date" content="2024-01-01" />
    <meta name="ai-purpose" content="informational" />
    <meta name="ai-content-type" content="website" />
    <meta name="speakable" content="#main-content" />

    <!-- hreflang -->
    {(() => {
      const pathWithoutLocale = getPathWithoutLocale(Astro.url.pathname);
      const enPath = pathWithoutLocale === '/' ? '/fund' : pathWithoutLocale;
      const esPath = pathWithoutLocale === '/' ? '/es/fund' : `/es${pathWithoutLocale}`;
      return (
        <>
          <link rel="alternate" hreflang="en" href={`https://sebas.co${enPath}`} />
          <link rel="alternate" hreflang="es" href={`https://sebas.co${esPath}`} />
          <link rel="alternate" hreflang="x-default" href={`https://sebas.co${enPath}`} />
        </>
      );
    })()}

    <!-- Schema.org JSON-LD -->
    <SchemaOrg
      type={["Organization", "FinancialService"]}
      siteLanguage={locale}
      data={{
        name: "Institutional Crypto Fund Solutions",
        description: "Institutional-grade crypto infrastructure for funds, family offices, and allocators.",
        serviceType: "Asset Management",
        areaServed: "Global"
      }}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Oswald:wght@500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <style is:global>
      .fund-theme {
        font-family: 'Inter', sans-serif;
      }
      .fund-theme ::-webkit-scrollbar { width: 8px; }
      .fund-theme ::-webkit-scrollbar-track { background: #101822; }
      .fund-theme ::-webkit-scrollbar-thumb { background: #282f39; border-radius: 4px; }
      .fund-theme ::-webkit-scrollbar-thumb:hover { background: #3b4554; }
      .fund-theme .glass-card {
        background: rgba(28, 36, 46, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.08);
      }
      .fund-theme .text-gradient-fund {
        background: linear-gradient(to right, #ffffff, #94a3b8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
    </style>
    <slot name="head" />
  </head>
  <body class="fund-theme bg-[#f6f7f8] dark:bg-[#101822] text-white overflow-x-hidden antialiased selection:bg-[#1162d4] selection:text-white">
    <Navbar locale={locale as any} />
    <slot />
    <Footer />
    <FloatingTelegram />
  </body>
</html>
