---
import '../styles/global.css';
import siteConfig from '../../config/site.config.ts';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import FloatingTelegram from '../components/shared/FloatingTelegram.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import { getPathWithoutLocale } from '../i18n/index';

interface Props {
  title?: string;
  description?: string;
  locale?: string;
  keywords?: string[];
}

const {
  title = 'Platform Monetization Engine',
  description = 'Turn dormant traffic into tangible assets. Advanced monetization engine for high-volume platforms and communities.',
  locale = 'en',
  keywords = [],
} = Astro.props;

const siteName = siteConfig.site.name;
const titleFull = `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titleFull}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <meta name="robots" content="index, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={titleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />

    <!-- Keywords -->
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

    <!-- AEO: AI Citation Hints -->
    <meta name="citation_title" content={titleFull} />
    <meta name="citation_author" content={siteName} />
    <meta name="citation_language" content={locale} />
    <meta name="citation_publication_date" content="2024-01-01" />
    <meta name="ai-purpose" content="informational" />
    <meta name="ai-content-type" content="website" />
    <meta name="speakable" content="#main-content" />

    <!-- hreflang -->
    {(() => {
      const pathWithoutLocale = getPathWithoutLocale(Astro.url.pathname);
      const enPath = pathWithoutLocale === '/' ? '/platform' : pathWithoutLocale;
      const esPath = pathWithoutLocale === '/' ? '/es/platform' : `/es${pathWithoutLocale}`;
      return (
        <>
          <link rel="alternate" hreflang="en" href={`https://sebas.co${enPath}`} />
          <link rel="alternate" hreflang="es" href={`https://sebas.co${esPath}`} />
          <link rel="alternate" hreflang="x-default" href={`https://sebas.co${enPath}`} />
        </>
      );
    })()}

    <!-- Schema.org JSON-LD -->
    <SchemaOrg
      type={["Organization", "Service"]}
      siteLanguage={locale}
      data={{
        name: "Platform Monetization Engine",
        description: "Advanced monetization for crypto platforms and communities.",
        serviceType: "Platform Monetization",
        areaServed: "Global"
      }}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Oswald:wght@500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Noto+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <style is:global>
      .platform-theme {
        font-family: 'Space Grotesk', 'Noto Sans', sans-serif;
      }
      .platform-theme .tech-grid-bg {
        background-size: 40px 40px;
        background-image: linear-gradient(to right, rgba(48, 57, 40, 0.3) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(48, 57, 40, 0.3) 1px, transparent 1px);
      }
      .platform-theme .glow-text {
        text-shadow: 0 0 20px rgba(140, 244, 37, 0.3);
      }
    </style>
    <slot name="head" />
  </head>
  <body class="platform-theme bg-[#f7f8f5] dark:bg-[#0a0a0a] text-gray-900 dark:text-white overflow-x-hidden antialiased">
    <Navbar locale={locale as any} />
    <slot />
    <Footer />
    <FloatingTelegram />
  </body>
</html>
