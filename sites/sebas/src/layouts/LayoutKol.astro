---
import '../styles/global.css';
import siteConfig from '../../config/site.config.ts';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import FloatingTelegram from '../components/shared/FloatingTelegram.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import { getPathWithoutLocale } from '../i18n/index';

interface Props {
  title?: string;
  description?: string;
  locale?: string;
  keywords?: string[];
}

const {
  title = 'KOL & Influencer Strategy',
  description = 'High-impact system to monetize your crypto influence. From $100K to $1M annually. VIP access, revenue sharing, and institutional connections.',
  locale = 'en',
  keywords = [],
} = Astro.props;

const siteName = siteConfig.site.name;
const titleFull = `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titleFull}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={titleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />

    <!-- Keywords -->
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

    <!-- AEO: AI Citation Hints -->
    <meta name="citation_title" content={titleFull} />
    <meta name="citation_author" content={siteName} />
    <meta name="citation_language" content={locale} />
    <meta name="citation_publication_date" content="2024-01-01" />
    <meta name="ai-purpose" content="informational" />
    <meta name="ai-content-type" content="website" />
    <meta name="speakable" content="#main-content" />

    <!-- hreflang -->
    {(() => {
      const pathWithoutLocale = getPathWithoutLocale(Astro.url.pathname);
      const enPath = pathWithoutLocale === '/' ? '/kol' : pathWithoutLocale;
      const esPath = pathWithoutLocale === '/' ? '/es/kol' : `/es${pathWithoutLocale}`;
      return (
        <>
          <link rel="alternate" hreflang="en" href={`https://sebas.co${enPath}`} />
          <link rel="alternate" hreflang="es" href={`https://sebas.co${esPath}`} />
          <link rel="alternate" hreflang="x-default" href={`https://sebas.co${enPath}`} />
        </>
      );
    })()}

    <!-- Schema.org JSON-LD -->
    <SchemaOrg
      type={["Organization", "Service"]}
      siteLanguage={locale}
      data={{
        name: "KOL & Influencer Monetization",
        description: "High-impact system to monetize crypto influence. VIP access, revenue sharing, and institutional connections.",
        serviceType: "Influencer Marketing & Monetization",
        areaServed: "Global"
      }}
    />

    <!-- Fonts: Inter + Oswald (global nav/footer) + Space Grotesk (KOL theme) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Oswald:wght@500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <style is:global>
      .kol-theme {
        font-family: 'Space Grotesk', sans-serif;
      }
      .kol-theme .glow-effect:hover {
        box-shadow: 0 0 20px rgba(242, 166, 13, 0.15);
        border-color: rgba(242, 166, 13, 0.4);
      }
      .kol-theme .text-gradient-gold {
        background: linear-gradient(90deg, #ffffff 0%, #f2a60d 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
    </style>
    <slot name="head" />
  </head>
  <body class="kol-theme bg-[#f8f7f5] dark:bg-[#221c10] text-slate-900 dark:text-white overflow-x-hidden antialiased">
    <Navbar locale={locale as any} />
    <slot />
    <Footer />
    <FloatingTelegram />
  </body>
</html>
